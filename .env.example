# Umia Analyst Agent — Environment Variables
# Copy to .env and fill in values

# ── Mode ──────────────────────────────────────────────────────────────────────
# demo       → mock signals from data/markets/*/raw_mock.json (no external APIs)
# production → live Apify + GitHub + Etherscan calls
UMIA_ENV=demo

# ── LLM Provider ─────────────────────────────────────────────────────────────
# anthropic (default) or openai
LLM_PROVIDER=anthropic

# Override model (optional — defaults: claude-opus-4-6 / gpt-4o)
# LLM_MODEL=claude-opus-4-6

# ── Claude API (Anthropic) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── OpenAI API (optional, only if LLM_PROVIDER=openai) ──────────────────────
# OPENAI_API_KEY=sk-xxxxx

# ── Signal Ingestion APIs (only needed in production mode) ───────────────────

# Apify — Telegram channel scraper + Twitter scraper
# https://apify.com — create a free account, grab your token
APIFY_TOKEN=

# GitHub REST API — commit cadence, contributor activity
# https://github.com/settings/tokens — fine-grained, read-only on public repos
GITHUB_TOKEN=

# Etherscan — on-chain wallet activity
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
