# Umia Analyst Agent — Environment Variables
# Copy to .env and fill in values

# ── Mode ──────────────────────────────────────────────────────────────────────
# demo       → mock signals from data/markets/*/raw_mock.json (no external APIs)
# production → live Apify + GitHub + Etherscan calls
UMIA_ENV=demo

# ── LLM Provider ─────────────────────────────────────────────────────────────
# anthropic (default) or openai
LLM_PROVIDER=anthropic

# Override model (optional — defaults: claude-opus-4-6 / gpt-4o)
# LLM_MODEL=claude-opus-4-6

# ── Claude API (Anthropic) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── OpenAI API (optional, only if LLM_PROVIDER=openai) ──────────────────────
# OPENAI_API_KEY=sk-xxxxx

# ── Signal Ingestion APIs (only needed in production mode) ───────────────────

# ── X402 Payment Protocol (Apify track — ETH Prague 2026) ────────────────────
# X402 pays for Apify Actor runs in USDC on Base mainnet via the mcpc CLI.
# Install: npm install -g @mcpc/cli  (or brew install mcpc)
# Fund:    mcpc wallet fund --chain base --amount 5  (5 USDC covers ~1000 runs)
# Verify:  mcpc x402 info
#
# Payment waterfall: mcpc X402 → APIFY_TOKEN fallback → mock
# If mcpc is not installed, APIFY_TOKEN is used instead (no X402 payment).
APIFY_TOKEN=

# xAI Grok API — Twitter/X search (replaces Apify Twitter scraper)
# https://x.ai — create account, generate API key
GROK_API_KEY=

# GitHub REST API — commit cadence, contributor activity
# https://github.com/settings/tokens — fine-grained, read-only on public repos
GITHUB_TOKEN=

# Etherscan — on-chain wallet activity
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── HuggingFace Inference API (only needed in production mode) ───────────────
# Remote sentiment inference — no local GPU / model downloads required.
# Models used:
#   social  → ElKulako/cryptobert
#   finance → StephanAkkerman/FinTwitBERT-sentiment
#   news    → ProsusAI/finbert
#   twitter → cardiffnlp/twitter-roberta-base-sentiment-latest
# https://huggingface.co/settings/tokens — create a read token (free tier is enough)
HF_TOKEN=
